# 应用配置
APP_NAME=Quantitative Trading Platform
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=<生成随机密钥>
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库配置
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_trade
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=<数据库密码>

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 行情配置
# 可选: eastmoney / sina / eastmoney_first / mock
MARKET_DATA_PROVIDER=eastmoney_first
MARKET_DATA_UPDATE_INTERVAL=5
DATA_AUTHENTICITY_STRICT=true
# 东方财富妙想Skills API密钥（基本面数据，每月300次免费额度）
EASTMONEY_SKILLS_API_KEY=

# Bark 推送通知（iOS 推送，获取 Key: https://api.day.app/）
BARK_KEY=

# 交易配置
# sandbox = 模拟成交，eastmoney = 实盘（需配置 EM_TRADE_AGENT_URL）
ORDER_EXECUTION_MODE=sandbox
# 实盘模式时需配置 Windows 端 eastmoney_agent.py 地址:
# EM_TRADE_AGENT_URL=http://192.168.1.100:8520
DEFAULT_MAX_POSITION_RATIO=0.3
DEFAULT_MAX_DAILY_LOSS=0.05
DEFAULT_STOP_LOSS_RATIO=0.02

# 自动交易（信号扫描 → 自动下单）
AUTO_TRADE_ENABLED=false
AUTO_TRADE_DRY_RUN=true
# 最低触发级别: STRONG_BUY / BUY / WATCH
AUTO_TRADE_MIN_LEVEL=STRONG_BUY
AUTO_TRADE_MAX_PER_ORDER=50000
AUTO_TRADE_MAX_DAILY_ORDERS=5
AUTO_TRADE_POSITION_PCT=0.1

# CORS（前端地址，逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs
