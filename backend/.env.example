# ============================================================
# 量化交易平台 - 生产环境配置模板
# 使用方法：cp .env.example .env 然后修改所有 <CHANGE_ME> 字段
# ============================================================

# --- 应用配置 ---
APP_NAME=Quantitative Trading Platform
APP_VERSION=1.0.0
# 生产环境必须设为 false（切换 PostgreSQL、启用限流、关闭调试日志）
DEBUG=false
# 用 python3 -c "import secrets; print(secrets.token_urlsafe(48))" 生成
SECRET_KEY=<CHANGE_ME>
# JWT 过期时间（分钟），生产建议 60-120
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- 数据库配置 ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_trade
POSTGRES_USER=quant_user
# 务必修改为强密码
POSTGRES_PASSWORD=<CHANGE_ME>

# --- Redis 配置 ---
REDIS_HOST=localhost
REDIS_PORT=6379
# 生产环境务必设置密码
REDIS_PASSWORD=<CHANGE_ME>
REDIS_DB=0

# --- Celery 配置 ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- 行情配置 ---
# 数据源：sina | eastmoney | eastmoney_skills | akshare (mock 仅限开发)
MARKET_DATA_PROVIDER=sina
# 行情刷新间隔（秒）
MARKET_DATA_UPDATE_INTERVAL=5
# 严格模式：数据获取失败直接报错，不降级到 mock
DATA_AUTHENTICITY_STRICT=true
# 东方财富妙想 Skills API（可选，每月300次免费额度）
EASTMONEY_SKILLS_API_KEY=
EASTMONEY_SKILLS_BASE_URL=https://mkapi2.dfcfs.com/finskillshub/api/claw/query

# --- 交叉校验（多渠道数据对比，可关闭以节省 API 调用）---
CROSS_VALIDATION_ENABLED=false
QUOTE_PRICE_DISCREPANCY_THRESHOLD=0.02
QUOTE_VOLUME_DISCREPANCY_THRESHOLD=0.05
KLINE_PRICE_DISCREPANCY_THRESHOLD=0.02
KLINE_VOLUME_DISCREPANCY_THRESHOLD=0.10
DISCREPANCY_MODERATE_THRESHOLD=0.01
DISCREPANCY_CRITICAL_THRESHOLD=0.05

# --- 交易配置 ---
# 执行模式：sandbox（模拟）| eastmoney（东方财富实盘）
ORDER_EXECUTION_MODE=sandbox
# 实盘时需配置 Windows 端代理地址：
# EM_TRADE_AGENT_URL=http://192.168.1.100:8520
DEFAULT_MAX_POSITION_RATIO=0.3
DEFAULT_MAX_DAILY_LOSS=0.05
DEFAULT_STOP_LOSS_RATIO=0.02

# --- CORS ---
# 生产环境必须指定前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:80,https://localhost

# --- 日志 ---
LOG_LEVEL=INFO
LOG_DIR=logs
